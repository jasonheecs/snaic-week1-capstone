    "axes[1].set_title('Churn Proportion', fontsize=13, fontweight='bold')\n",
    "\n",
    "plt.suptitle('Target Variable: Churn Distribution', fontsize=15, fontweight='bold', y=1.02)\n",
    "plt.tight_layout()\n",
    "plt.show()"
